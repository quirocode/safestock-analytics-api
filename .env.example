NODE_ENV=development
PORT=3000
JWT_SECRET=change_this_secret_before_running
JWT_EXPIRES_IN=8h
BCRYPT_ROUNDS=12
REPORT_TIME_ZONE=America/Lima
FRONTEND_ORIGIN=http://localhost:5173

DB_HOST=localhost
DB_PORT=5432
DB_NAME=safestock_analytics
DB_USER=safestock_user
DB_PASSWORD=safestock_password
DB_SSL=false

# SMTP. Para Gmail usa una contraseña de aplicación, no tu contraseña normal.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=notificaciones@empresa.com
SMTP_PASSWORD=change_this_app_password
EMAIL_FROM="SafeStock Analytics <notificaciones@empresa.com>"
